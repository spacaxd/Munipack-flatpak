<component type="desktop-application">
  <id>cz.muni.physics.munipack</id>
  <name>Munipack</name>
  <summary>A tool for advanced scientific processing of astronomical images</summary>
  <metadata_license>FSFAP</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>
  <developer id="cz.muni.physics.munipack">
    <name>Filip Hroch / Masaryk University (Packaged by Martin Špaček)</name>
  </developer>
  <description>
    <p>Munipack is a free open source tool for an advanced scientific processing of astronomical images.</p>
    <p>The goal of Munipack project is to develop, to implement, and to prove of general methods, recognised among all the fundamental principles of nature, for reliable, reproducible, and efficient astronomical image data processing.</p>
  </description>
